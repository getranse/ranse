# Ranse environment — copy to .dev.vars for local dev, or fill these in
# during the Deploy-to-Cloudflare prompts.
#
# IMPORTANT: leave COOKIE_SIGNING_KEY, ADMIN_BOOTSTRAP_TOKEN, and any API
# keys BLANK here. `bun run setup` generates strong random values locally;
# `bun run deploy` generates them at deploy time. If you paste weak values
# here, they'll be prefilled for every future install of your fork.

APP_URL=
ADMIN_EMAIL=
SUPPORT_DOMAIN=

# Session + bootstrap — generated automatically, do not prefill.
COOKIE_SIGNING_KEY=
ADMIN_BOOTSTRAP_TOKEN=

# LLM — leave unset to default to Workers AI via the `AI` binding.
# Set any one of these to enable the corresponding provider.
# Format: "provider/model-id" in LLM_DEFAULT_MODEL.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=

# AI Gateway (optional — enables unified analytics + fallback)
CLOUDFLARE_AI_GATEWAY=ranse
CLOUDFLARE_AI_GATEWAY_TOKEN=
CLOUDFLARE_AI_GATEWAY_URL=none
